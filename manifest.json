{
  "manifest_version": 3,
  "name": "Tracker Lens",
  "version": "1.0.0",
  "description": "Visualize the relationships between sites you visit and the third-party trackers they load.",

  "icons": {
    "48": "assets/lightbeam-48.png",
    "96": "assets/lightbeam-96.png"
  },

  "permissions": [
    "webRequest",
    "tabs",
    "cookies",
    "downloads",
    "scripting",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_icon": "assets/lightbeam-48.png",
    "default_title": "Tracker Lens",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "sw.js"
  }
}
